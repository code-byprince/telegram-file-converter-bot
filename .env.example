# Yeh file copy karke naam .env rakho (local testing ke liye)
# Render pe yeh values Dashboard > Environment me daalni hain, .env file ki zaroorat nahi

BOT_TOKEN=your_bot_token_from_botfather
PORT=10000
MAX_FILE_SIZE_MB=20

# Apna Telegram numeric user ID (@userinfobot se lo) - /stats command sirf isi ID ko dikhega
ADMIN_ID=your_telegram_user_id
